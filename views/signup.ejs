<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="/tailwind.css" rel="stylesheet">
    <title>Members Only - Sign Up</title>
  </head>
  <body class="flex flex-col">
    <%- include("partials/header.ejs") %>

    <form method="POST" action="/signup" class="p-4 flex flex-col items-center gap-5 max-w-lg self-center">
      <div class="w-full grid grid-cols-2 gap-8">
        <label for="first_name" class="justify-self-end self-center">First Name:</label>
        
        <input type="text" id="first_name" name="first_name" class="w-full px-2 py-1 border rounded" required>
      </div>

      <div class="w-full grid grid-cols-2 gap-8">
        <label for="last_name" class="justify-self-end self-center">Last Name:</label>

        <input type="text" id="last_name" name="last_name" class="w-full px-2 py-1 border rounded" required>
      </div>

      <div class="w-full grid grid-cols-2 gap-8">
        <label for="email" class="justify-self-end self-center">Email Address:</label>

        <input type="email" id="email" name="email" class="w-full px-2 py-1 border rounded" required>
      </div>

      <div class="w-full grid grid-cols-2 gap-8">
        <label for="password" class="justify-self-end self-center">Password:</label>

        <input type="password" id="password" name="password" class="w-full px-2 py-1 border rounded" required>
      </div>

      <div class="w-full grid grid-cols-2 gap-8">
        <label for="confirm_pw" class="justify-self-end self-center">Confirm Password:</label>
        
        <input type="password" id="confirm_pw" name="confirm_pw" class="w-full px-2 py-1 border rounded" required>
      </div>

      <button type="submit" class="px-4 py-1 rounded-lg bg-blue-400 text-white mt-4 cursor-pointer">Sign Up</button>
    </form>
  </body>
</html>